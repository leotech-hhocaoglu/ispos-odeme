# Frontend
VITE_API_BASE_URL=http://localhost:8080/api

# Backend
SERVER_PORT=8080
APP_FRONTEND_URL=http://localhost:5173
APP_BACKEND_PUBLIC_URL=http://localhost:8080

# Auth
AUTH_TOKEN_SECRET=change-me-for-local-development
AUTH_TOKEN_TTL_MINUTES=60
SESSION_COOKIE_NAME=ispos_session

# İşPOS / Sanal POS
ISPOS_MODE=sandbox
ISPOS_BASE_URL=https://sandbox-provider-url.example
ISPOS_MERCHANT_ID=replace-with-sandbox-merchant-id
ISPOS_CLIENT_ID=replace-with-sandbox-client-id
ISPOS_STORE_KEY=replace-with-sandbox-store-key
ISPOS_API_USERNAME=replace-with-sandbox-api-username
ISPOS_API_PASSWORD=replace-with-sandbox-api-password
ISPOS_SUCCESS_URL=http://localhost:8080/api/payments/ispos/callback
ISPOS_FAILURE_URL=http://localhost:8080/api/payments/ispos/callback

# Logging
LOG_LEVEL=INFO
